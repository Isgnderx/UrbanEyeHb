{
    "version": 2,
    "builds": [
        {
            "src": "backend/api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "Front/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(health|token)$",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/api/(.*)",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/api/v1/(.*)",
            "dest": "backend/api/index.py"
        }
    ]
}