{
    "version": 2,
    "builds": [
        {
            "src": "backend/api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "Front/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/health",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/token",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/$",
            "dest": "/Front/index.html"
        }
    ]
}